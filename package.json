{
  "name": "image-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node scripts/clean-next-cache.mjs && next dev",
    "dev:restart": "node scripts/kill-dev-ports.mjs && node scripts/clean-next-cache.mjs && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "start:clean": "node scripts/restart-prod.mjs",
    "generate:style-previews": "node scripts/generate-style-previews.mjs",
    "generate:explore-seeds": "node scripts/generate-explore-seeds.mjs",
    "generate:assets": "npm run generate:style-previews && npm run generate:explore-seeds",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.8",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "uuid": "^11.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.8",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
