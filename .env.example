# Optional: Pollinations API key for img2img reference images or fallback if free endpoint is down
# POLLINATIONS_API_KEY=sk_...

# Optional: higher-quality single-image upscale via OpenAI
# OPENAI_API_KEY=sk-...

# Without any keys, Lumina uses Pollinations (Flux) for free text-to-image generation.

# Google OAuth (required for "Continue with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000, https://your-app.vercel.app
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
